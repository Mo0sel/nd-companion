<div class="nd-companion__shell">

  <header class="nd-global-header">
    <div class="nd-global-header__brand">N&amp;D Companion</div>
    <div class="nd-global-search" data-global-search>
      <span class="nd-global-search__icon" aria-hidden="true">⌕</span>
      <input
        type="search"
        data-global-search-input
        placeholder="Search campaign..."
        aria-label="Search campaign"
        aria-controls="nd-global-search-results"
        aria-expanded="false"
        autocomplete="off"
      >
      <kbd>Ctrl K</kbd>
      <div
        id="nd-global-search-results"
        class="nd-global-search__results"
        data-global-search-results
        role="listbox"
        hidden
      ></div>
    </div>
  </header>

  <nav class="nd-workspace-switcher" aria-label="Workspaces">
    <button
      type="button"
      class="nd-workspace-switcher__button"
      data-action="setWorkspace"
      data-workspace="play"
      aria-pressed="true"
    >Play</button>
    <button
      type="button"
      class="nd-workspace-switcher__button"
      data-action="setWorkspace"
      data-workspace="prepare"
      aria-pressed="false"
    >Prepare</button>
    <button
      type="button"
      class="nd-workspace-switcher__button"
      data-action="setWorkspace"
      data-workspace="campaign"
      aria-pressed="false"
    >Campaign</button>
    <button
      type="button"
      class="nd-workspace-switcher__button"
      data-action="setWorkspace"
      data-workspace="notes"
      aria-pressed="false"
    >Actors</button>
  </nav>

  <div class="nd-workspace-region">

    {{!-- PLAY — stable live-session dashboard --}}
    <section class="nd-workspace nd-play" data-workspace-panel="play" aria-label="Play workspace">

      {{!-- Stable campaign header: campaign-level information only --}}
      <div class="nd-play__row nd-play__row--top">
        <section class="nd-play-campaign" data-play-campaign aria-label="Campaign Context">
          <div class="nd-play-campaign__main">
            <div class="nd-play-campaign__title" data-context="campaign-title"></div>
            <div class="nd-play-campaign__location" data-context="scene">
              <span class="nd-play-campaign__location-label">Current Location</span>
              <span class="nd-play-campaign__location-value" data-context-value>No active scene</span>
            </div>
          </div>
          <div class="nd-play-campaign__focus">
            <span class="nd-play-campaign__focus-label">Focused Character</span>
            <span class="nd-play-campaign__focus-value" data-focus="name">Party</span>
          </div>
        </section>

      </div>

      {{!-- Row 2: Playbook hero --}}
      <div class="nd-play__row nd-play__row--hero">
        <article class="nd-playbook-card" data-playbook aria-label="Current Session Entry">
          <div class="nd-playbook-card__accent" data-playbook="accent" aria-hidden="true"></div>
          <div class="nd-playbook-card__body">
            <header class="nd-playbook-card__header">
              <div class="nd-playbook-card__identity">
                <button type="button" class="nd-button nd-button--nav nd-playbook-card__nav" data-playbook-nav="prev" aria-label="Previous entry">←</button>
                <div class="nd-playbook-card__counter nd-mono" data-playbook="counter" aria-label="Entry position">
                  <span class="nd-playbook-card__counter-current" data-playbook-counter="current">0</span>
                  <span class="nd-playbook-card__counter-sep">/</span>
                  <span class="nd-playbook-card__counter-total" data-playbook-counter="total">0</span>
                </div>
                <div class="nd-playbook-card__title-block">
                <div class="nd-playbook-card__eyebrow">Current Entry</div>
                  <h2 class="nd-playbook-card__title nd-page-title" data-playbook="title"></h2>
                </div>
                <button type="button" class="nd-button nd-button--nav nd-playbook-card__nav" data-playbook-nav="next" aria-label="Next entry">→</button>
              </div>
              <div class="nd-entry-state" data-playbook-state data-state="active" role="status" aria-label="Entry status">
                <span class="nd-entry-state__label">Entry State</span>
                <span class="nd-entry-state__value">
                  <span class="nd-entry-state__dot" aria-hidden="true"></span>
                  <span data-playbook-state-value>Active</span>
                </span>
              </div>
            </header>

            <div class="nd-play-entry-grid">
              <section class="nd-play-entry-column" aria-labelledby="nd-play-scene-flow">
                <h3 class="nd-section-title" id="nd-play-scene-flow">Scene Flow</h3>

                <section class="nd-panel-card nd-play-entry-card nd-play-entry-card--speech" data-playbook-field-block="speechNotes">
                  <div class="nd-field-label nd-play-entry-card__label">Speech Notes</div>
                  <div
                    class="nd-field-control nd-play-entry-card__content nd-richtext nd-play-inline-editor"
                    data-playbook="speechNotes"
                    data-placeholder="Add dialogue or read-aloud text..."
                    role="textbox"
                    aria-label="Speech Notes"
                  ></div>
                </section>

                <details class="nd-panel-card nd-play-entry-card nd-play-entry-card--setup" data-playbook-field-block="setup" open>
                  <summary>
                    <span class="nd-field-label">Setup</span>
                    <span class="nd-play-entry-card__collapse-label">Collapse</span>
                  </summary>
                  <div class="nd-play-entry-card__content nd-richtext" data-playbook="setup"></div>
                </details>

                <section class="nd-panel-card nd-play-entry-card nd-play-entry-card--objective" data-playbook-field-block="objective">
                  <header class="nd-play-entry-card__header">
                    <div class="nd-field-label nd-play-entry-card__label">Objectives</div>
                    <button type="button" class="nd-button nd-button--ghost" data-objective-add aria-label="Add objective">+ Objective</button>
                  </header>
                  <div
                    class="nd-field-control nd-play-entry-card__content nd-richtext nd-play-inline-editor"
                    data-playbook="objective"
                    data-placeholder="Add an objective..."
                    role="textbox"
                    aria-label="Objectives"
                  ></div>
                </section>

                <section class="nd-panel-card nd-play-entry-card nd-play-entry-card--experience" data-playbook-field-block="experience">
                  <div class="nd-field-label nd-play-entry-card__label">Experience</div>
                  <div
                    class="nd-field-control nd-play-entry-card__content nd-richtext nd-play-inline-editor"
                    data-playbook="experience"
                    data-placeholder="Add XP or reward..."
                    role="textbox"
                    aria-label="Experience"
                  ></div>
                </section>
              </section>

              <section class="nd-play-entry-column" aria-labelledby="nd-play-response-notes">
                <h3 class="nd-section-title" id="nd-play-response-notes">Response &amp; Notes</h3>

                <section class="nd-panel-card nd-play-entry-card" data-playbook-field-block="twist">
                  <div class="nd-field-label nd-play-entry-card__label">Twist</div>
                  <div class="nd-play-entry-card__content nd-richtext" data-playbook="twist"></div>
                </section>

                <section class="nd-panel-card nd-play-entry-card" data-playbook-field-block="possibleOutcomes">
                  <div class="nd-field-label nd-play-entry-card__label">Possible Outcomes</div>
                  <div class="nd-play-entry-card__content nd-richtext" data-playbook="possibleOutcomes"></div>
                </section>

                <section class="nd-panel-card nd-play-entry-card nd-play-entry-card--notes" data-playbook-field-block="gmNotes">
                  <div class="nd-field-label nd-play-entry-card__label">Notes</div>
                  <div
                    class="nd-field-control nd-play-entry-card__content nd-richtext nd-play-inline-editor"
                    data-playbook="gmNotes"
                    data-placeholder="Add live entry notes..."
                    role="textbox"
                    aria-label="Entry Notes"
                  ></div>
                </section>

                <section class="nd-panel-card nd-play-entry-card nd-play-entry-card--references" data-playbook-field-block="entities">
                  <div class="nd-field-label nd-play-entry-card__label">References</div>
                  <div class="nd-playbook-card__chips" data-playbook="entities"></div>
                </section>
              </section>
            </div>
          </div>
        </article>
      </div>

      {{!-- Session Notes and permanent Session Summary share remaining space --}}
      <div class="nd-play__row nd-play__row--bottom">
        <section
          class="nd-play-notes"
          data-live-notes-root
          data-resizable-panel="play-session-notes"
          data-resize-min="140"
          aria-label="Session Notes"
        >
          <header class="nd-play-notes__header">
            <span class="nd-play-notes__title">Session Notes</span>
            <div class="nd-play-notes__saved">
              <span class="nd-play-notes__dot" aria-hidden="true"></span>
              <span>auto-saved</span>
              <span class="nd-live-notes__status" data-live-notes-status hidden></span>
            </div>
          </header>
          <div
            class="nd-live-notes nd-play-notes__editor nd-richtext"
            data-storage="sessionNotes"
            data-storage-html
            data-placeholder="Session Notes..."
            role="textbox"
            aria-label="Session Notes"
          ></div>
        </section>

        <section
          class="nd-play-notes nd-play-summary"
          data-live-notes-root
          data-resizable-panel="play-session-summary"
          data-resize-min="140"
          aria-label="Session Summary"
        >
          <header class="nd-play-notes__header">
            <span class="nd-play-notes__title">Session Summary</span>
            <div class="nd-play-notes__saved">
              <span class="nd-play-notes__dot" aria-hidden="true"></span>
              <span>auto-saved</span>
              <span class="nd-live-notes__status" data-live-notes-status hidden></span>
            </div>
          </header>
          <div
            class="nd-live-notes nd-play-notes__editor nd-richtext"
            data-storage="sessionSummary"
            data-storage-html
            data-placeholder="Write the permanent session summary..."
            role="textbox"
            aria-label="Session Summary"
          ></div>
        </section>
      </div>
    </section>

    {{!-- CAMPAIGN — lightweight Session and Thread database --}}
    <section
      class="nd-workspace nd-campaign"
      data-workspace-panel="campaign"
      data-campaign-workspace
      aria-label="Campaign workspace"
      hidden
    >
      <header class="nd-campaign-header">
        <div class="nd-campaign-header__title">Campaign</div>
        <div class="nd-campaign-header__current">
          <span>Current Session</span>
          <strong data-campaign-current-session>Session 1</strong>
        </div>
      </header>

      <div class="nd-quest-layout">
        <aside class="nd-quest-sidebar" aria-label="Quest navigation">
          <div class="nd-quest-sidebar__section">
            <div class="nd-quest-sidebar__heading">
              <span>Main Quests</span>
              <button type="button" data-new-quest="MAIN" aria-label="New Main Quest">+</button>
            </div>
            <div data-quest-list="MAIN"></div>
          </div>
          <div class="nd-quest-sidebar__section">
            <div class="nd-quest-sidebar__heading">
              <span>Side Quests</span>
              <button type="button" data-new-quest="SIDE" aria-label="New Side Quest">+</button>
            </div>
            <div data-quest-list="SIDE"></div>
          </div>
          <div class="nd-quest-sidebar__section">
            <div class="nd-quest-sidebar__heading">
              <span>Companion Quests</span>
              <button type="button" data-new-quest="COMPANION" aria-label="New Companion Quest">+</button>
            </div>
            <div data-quest-list="COMPANION"></div>
          </div>
        </aside>

        <main class="nd-quest-panel">
          <div class="nd-quest-empty" data-quest-empty>
            Select a Quest or create one to begin writing your campaign.
          </div>

          <section data-quest-editor hidden>
            <header class="nd-campaign-panel__header">
              <div>
                <div class="nd-campaign-panel__eyebrow">Campaign Quest</div>
                <h2>Quest</h2>
              </div>
              <span class="nd-campaign-save-status" data-quest-saved hidden></span>
            </header>

            <div class="nd-campaign-thread-fields">
              <label class="nd-campaign-field nd-campaign-field--wide">
                <span>Title</span>
                <input type="text" data-quest-title placeholder="Quest title">
              </label>
              <label class="nd-campaign-field">
                <span>Status</span>
                <select data-quest-status>
                  <option value="OPEN">OPEN</option>
                  <option value="ACTIVE">ACTIVE</option>
                  <option value="RESOLVED">RESOLVED</option>
                </select>
              </label>
              <label class="nd-campaign-field">
                <span>Category</span>
                <select data-quest-category>
                  <option value="MAIN">MAIN QUEST</option>
                  <option value="SIDE">SIDE QUEST</option>
                  <option value="COMPANION">COMPANION QUEST</option>
                </select>
              </label>
            </div>

            <div class="nd-campaign-field nd-campaign-field--notes">
              <span>Overview</span>
              <div class="nd-richtext-toolbar" data-richtext-toolbar role="toolbar" aria-label="Quest formatting">
                <button type="button" data-richtext-command="bold" aria-label="Bold"><strong>B</strong></button>
                <button type="button" data-richtext-command="italic" aria-label="Italic"><em>I</em></button>
                <button type="button" data-richtext-command="underline" aria-label="Underline"><u>U</u></button>
                <span class="nd-richtext-toolbar__divider" aria-hidden="true"></span>
                <button type="button" data-richtext-command="heading" data-richtext-value="h2" aria-label="Heading 2">H2</button>
                <button type="button" data-richtext-command="heading" data-richtext-value="h3" aria-label="Heading 3">H3</button>
                <button type="button" data-richtext-command="list" data-richtext-value="ul" aria-label="Bullet list">• List</button>
                <button type="button" data-richtext-command="list" data-richtext-value="ol" aria-label="Numbered list">1. List</button>
                <label class="nd-richtext-toolbar__color">
                  <select data-richtext-color aria-label="Text color">
                    <option value="default">Default</option>
                    <option value="blue">Blue</option>
                    <option value="green">Green</option>
                    <option value="yellow">Yellow</option>
                    <option value="orange">Orange</option>
                    <option value="red">Red</option>
                    <option value="purple">Purple</option>
                    <option value="gray">Gray</option>
                  </select>
                </label>
                <button type="button" data-richtext-command="clear" aria-label="Clear formatting">Clear</button>
              </div>
              <div
                class="nd-richtext nd-richtext--editor nd-quest-overview"
                data-quest-overview
                data-richtext-editor
                contenteditable="true"
                data-placeholder="Write the long-form campaign overview..."
              ></div>
            </div>

            <div class="nd-quest-actions">
              <button type="button" class="nd-campaign-save" data-save-quest>Save Quest</button>
            </div>

            <section class="nd-quest-entries">
              <header>
                <div>
                  <div class="nd-campaign-panel__eyebrow">Playable Content</div>
                  <h3>Quest Entries</h3>
                </div>
                <button type="button" class="nd-campaign-new-thread" data-add-quest-entry>
                  + New Entry
                </button>
              </header>
              <div data-quest-entry-list></div>
            </section>
          </section>

          <section data-quest-session-view hidden>
            <header class="nd-campaign-panel__header">
              <div>
                <div class="nd-campaign-panel__eyebrow">Current Session</div>
                <h2 data-campaign-session="title">Session 1</h2>
              </div>
              <span class="nd-campaign-status" data-campaign-session="status">active</span>
            </header>
            <section class="nd-campaign-content-block">
              <h3>Session Summary</h3>
              <div class="nd-richtext" data-campaign-session="summary"></div>
            </section>
            <section class="nd-campaign-content-block">
              <h3>Session Notes</h3>
              <div class="nd-richtext" data-campaign-session="notes"></div>
            </section>
            <section class="nd-campaign-content-block">
              <h3>Session Plan</h3>
              <div class="nd-campaign-beats" data-campaign-session-beats></div>
            </section>
          </section>
        </main>
      </div>

      <div class="nd-campaign-layout" hidden aria-hidden="true">
        <aside class="nd-campaign-sidebar" aria-label="Campaign navigation">
          <h2 class="nd-campaign-sidebar__title">Campaign</h2>

          <div class="nd-campaign-sidebar__section">
            <div class="nd-campaign-sidebar__label">Sessions</div>
            <button
              type="button"
              class="nd-campaign-sidebar__item"
              data-campaign-select-session
            >Session 1</button>
          </div>

          <div class="nd-campaign-sidebar__section">
            <button
              type="button"
              class="nd-campaign-sidebar__label nd-campaign-sidebar__label--button"
              data-campaign-select-threads
            >Threads</button>
            <div class="nd-campaign-sidebar__threads" data-campaign-sidebar-threads></div>
            <button type="button" class="nd-campaign-new-thread" data-campaign-new-thread>
              + New Thread
            </button>
          </div>
        </aside>

        <main class="nd-campaign-panel">
          <section data-campaign-view="session" aria-label="Session">
            <header class="nd-campaign-panel__header">
              <div>
                <div class="nd-campaign-panel__eyebrow">Session</div>
                <h2 data-campaign-session="title">Session 1</h2>
              </div>
              <span
                class="nd-campaign-status nd-campaign-status--session"
                data-campaign-session="status"
              >active</span>
            </header>

            <dl class="nd-campaign-session-meta">
              <div>
                <dt>Session Number</dt>
                <dd data-campaign-session="number">1</dd>
              </div>
              <div>
                <dt>Real Date</dt>
                <dd data-campaign-session="real-date">—</dd>
              </div>
              <div>
                <dt>In-game Date</dt>
                <dd data-campaign-session="in-game-date">—</dd>
              </div>
            </dl>

            <section class="nd-campaign-content-block">
              <h3>Session Summary</h3>
              <div class="nd-richtext" data-campaign-session="summary"></div>
            </section>

            <section class="nd-campaign-content-block">
              <h3>Session Notes</h3>
              <div class="nd-richtext" data-campaign-session="notes"></div>
            </section>

            <section class="nd-campaign-content-block">
              <h3>Beats</h3>
              <div class="nd-campaign-beats" data-campaign-session-beats></div>
            </section>
          </section>

          <section data-campaign-view="threads" aria-label="Threads" hidden>
            <header class="nd-campaign-panel__header">
              <div>
                <div class="nd-campaign-panel__eyebrow">Campaign</div>
                <h2>Threads</h2>
              </div>
              <button type="button" class="nd-campaign-new-thread" data-campaign-new-thread>
                + New Thread
              </button>
            </header>
            <div class="nd-campaign-thread-empty" data-campaign-thread-empty>
              <p>No narrative threads yet.</p>
              <button type="button" class="nd-campaign-new-thread" data-campaign-new-thread>
                + New Thread
              </button>
            </div>
            <div class="nd-campaign-thread-list" data-campaign-thread-list></div>
          </section>

          <section
            data-campaign-view="thread"
            data-campaign-thread-editor
            aria-label="Thread editor"
            hidden
          >
            <header class="nd-campaign-panel__header">
              <div>
                <div class="nd-campaign-panel__eyebrow">Narrative Thread</div>
                <h2>Thread Editor</h2>
              </div>
              <span class="nd-campaign-save-status" data-campaign-thread-saved hidden></span>
            </header>

            <div class="nd-campaign-thread-fields">
              <label class="nd-campaign-field nd-campaign-field--wide">
                <span>Title</span>
                <input type="text" data-campaign-thread-title placeholder="Thread title">
              </label>
              <label class="nd-campaign-field">
                <span>Status</span>
                <select data-campaign-thread-status>
                  <option value="OPEN">OPEN</option>
                  <option value="ACTIVE">ACTIVE</option>
                  <option value="RESOLVED">RESOLVED</option>
                </select>
              </label>
              <label class="nd-campaign-field">
                <span>Type <small>Optional</small></span>
                <input type="text" data-campaign-thread-type placeholder="Type">
              </label>
            </div>

            <div class="nd-campaign-field nd-campaign-field--notes">
              <span>Notes</span>
              <div
                class="nd-richtext-toolbar"
                data-richtext-toolbar
                role="toolbar"
                aria-label="Thread Notes formatting"
              >
                <button type="button" data-richtext-command="bold" aria-label="Bold"><strong>B</strong></button>
                <button type="button" data-richtext-command="italic" aria-label="Italic"><em>I</em></button>
                <button type="button" data-richtext-command="underline" aria-label="Underline"><u>U</u></button>
                <span class="nd-richtext-toolbar__divider" aria-hidden="true"></span>
                <button type="button" data-richtext-command="heading" data-richtext-value="h2" aria-label="Heading 2">H2</button>
                <button type="button" data-richtext-command="heading" data-richtext-value="h3" aria-label="Heading 3">H3</button>
                <span class="nd-richtext-toolbar__divider" aria-hidden="true"></span>
                <button type="button" data-richtext-command="list" data-richtext-value="ul" aria-label="Bullet list">• List</button>
                <button type="button" data-richtext-command="list" data-richtext-value="ol" aria-label="Numbered list">1. List</button>
                <span class="nd-richtext-toolbar__divider" aria-hidden="true"></span>
                <label class="nd-richtext-toolbar__color">
                  <select data-richtext-color aria-label="Text color">
                    <option value="default">Default</option>
                    <option value="blue">Blue</option>
                    <option value="green">Green</option>
                    <option value="yellow">Yellow</option>
                    <option value="orange">Orange</option>
                    <option value="red">Red</option>
                    <option value="purple">Purple</option>
                    <option value="gray">Gray</option>
                  </select>
                </label>
                <button type="button" data-richtext-command="clear" aria-label="Clear formatting">Clear</button>
              </div>
              <div
                class="nd-richtext nd-richtext--editor nd-campaign-thread-notes"
                data-richtext-editor
                data-campaign-thread-notes
                contenteditable="true"
                data-placeholder="Thread notes..."
                role="textbox"
                aria-label="Thread Notes"
              ></div>
            </div>

            <section class="nd-campaign-references" aria-label="References">
              <h3>References</h3>
              <details>
                <summary>Beats</summary>
                <div data-campaign-thread-refs="beats"></div>
              </details>
              <details>
                <summary>Characters</summary>
                <div data-campaign-thread-refs="characters"></div>
              </details>
              <details>
                <summary>Locations</summary>
                <div data-campaign-thread-refs="locations"></div>
              </details>
              <details>
                <summary>Items</summary>
                <div data-campaign-thread-refs="items"></div>
              </details>
            </section>

            <div class="nd-campaign-thread-actions">
              <button type="button" class="nd-campaign-save" data-campaign-save-thread>
                Save
              </button>
            </div>
          </section>
        </main>
      </div>
    </section>

    <section class="nd-workspace" data-workspace-panel="notes" aria-label="Actors workspace" hidden>
      <div class="nd-actors-grid">
        <section class="nd-companion-memory-card nd-card" data-companion-memory data-live-notes-root aria-label="Companion Memory">
          <header class="nd-card__header">
            <span class="nd-card__accent" aria-hidden="true"></span>
            <h2 class="nd-card__label">Companion Memory</h2>
            <span class="nd-companion-memory-card__focus" data-focus="name">Party</span>
            <span class="nd-live-notes__status" data-live-notes-status hidden></span>
          </header>
          <div class="nd-companion-memory-card__body">
            <p class="nd-companion-memory__empty" data-memory-empty>
              Select an Actor to view Companion Memory.
            </p>
            <div class="nd-richtext-toolbar" data-richtext-toolbar data-memory-toolbar role="toolbar" aria-label="Companion Memory formatting" hidden>
              <button type="button" data-richtext-command="bold" aria-label="Bold"><strong>B</strong></button>
              <button type="button" data-richtext-command="italic" aria-label="Italic"><em>I</em></button>
              <button type="button" data-richtext-command="underline" aria-label="Underline"><u>U</u></button>
              <span class="nd-richtext-toolbar__divider" aria-hidden="true"></span>
              <button type="button" data-richtext-command="heading" data-richtext-value="h2">H2</button>
              <button type="button" data-richtext-command="heading" data-richtext-value="h3">H3</button>
              <button type="button" data-richtext-command="list" data-richtext-value="ul">• List</button>
              <button type="button" data-richtext-command="list" data-richtext-value="ol">1. List</button>
              <button type="button" data-richtext-command="clear">Clear</button>
            </div>
            <div
              class="nd-card__text nd-live-notes nd-companion-memory-card__editor nd-richtext nd-richtext--editor"
              data-memory-editor
              data-richtext-editor
              data-placeholder="Record everything the Companion permanently knows..."
              role="textbox"
              aria-label="Companion Memory"
              hidden
            ></div>
          </div>
        </section>

        <section class="nd-reputation-card nd-card" aria-label="Reputation">
          <header class="nd-card__header">
            <span class="nd-card__accent" aria-hidden="true"></span>
            <h2 class="nd-card__label">Reputation</h2>
          </header>
          <div class="nd-reputation-card__empty">
            <strong>No reputation network yet.</strong>
            <span>Relationships and social connections will appear here in a future update.</span>
          </div>
        </section>
      </div>
    </section>

    <section class="nd-workspace" data-workspace-panel="prepare" aria-label="Prepare workspace" hidden>
      <article class="nd-card nd-card--playbook-prepare" data-playbook-prepare data-live-notes-root aria-label="Session Builder">
        <header class="nd-card__header">
          <span class="nd-card__accent" aria-hidden="true"></span>
          <h2 class="nd-card__label">Session Builder</h2>
          <span class="nd-live-notes__status" data-live-notes-status hidden></span>
        </header>

        <div class="nd-playbook-prepare">
          <div class="nd-playbook-prepare__sidebar">
            <div class="nd-playbook-prepare__section-title">Prepared Entries</div>
            <button type="button" class="nd-session-import__open" data-open-campaign-import>
              Import from Campaign
            </button>
            <button type="button" class="nd-playbook-prepare__add" data-playbook-add-beat>
              + Add Entry
            </button>
            <div class="nd-playbook-prepare__list" data-playbook-prepare-list role="list"></div>
          </div>

          <div class="nd-playbook-prepare__main">
            <div class="nd-playbook-prepare__section-title">Current Entry</div>
            <div class="nd-playbook-prepare__empty" data-playbook-prepare-empty hidden>
              <p class="nd-card__text nd-workspace__placeholder">
                No entries yet. Import from Campaign or add an entry.
              </p>
              <button type="button" class="nd-playbook-prepare__add" data-playbook-add-beat>
                + Add Entry
              </button>
            </div>

            <div class="nd-playbook-prepare__editor" data-playbook-prepare-editor>
              <div class="nd-playbook-prepare__actions">
                <button type="button" class="nd-playbook-prepare__current-button" data-playbook-set-current>
                  Set as Current Entry
                </button>
              </div>

              <div class="nd-playbook__field">
                <span class="nd-playbook__field-label">Title</span>
                <div
                  class="nd-card__text nd-live-notes nd-playbook-prepare__field"
                  data-playbook-field="title"
                  data-placeholder="Entry title..."
                  role="textbox"
                  aria-label="Entry title"
                ></div>
              </div>

              <div class="nd-playbook__field">
                <span class="nd-playbook__field-label">Speech Notes</span>
                <div
                  class="nd-card__text nd-live-notes nd-playbook-prepare__field nd-richtext nd-richtext--editor"
                  data-playbook-field="speechNotes"
                  data-richtext-editor
                  data-placeholder="Dialogue, read-aloud text, and talking points..."
                  role="textbox"
                  aria-label="Speech Notes"
                ></div>
              </div>

              <div class="nd-playbook__field">
                <span class="nd-playbook__field-label">Objective</span>
                <div
                  class="nd-card__text nd-live-notes nd-playbook-prepare__field nd-richtext nd-richtext--editor"
                  data-playbook-field="objective"
                  data-richtext-editor
                  data-placeholder="Objective..."
                  role="textbox"
                  aria-label="Entry objective"
                ></div>
              </div>

              <div class="nd-playbook__field">
                <span class="nd-playbook__field-label">Setup</span>
                <div
                  class="nd-card__text nd-live-notes nd-playbook-prepare__field nd-richtext nd-richtext--editor"
                  data-playbook-field="setup"
                  data-richtext-editor
                  data-placeholder="Scene setup..."
                  role="textbox"
                  aria-label="Setup"
                ></div>
              </div>

              <div class="nd-playbook__field">
                <span class="nd-playbook__field-label">Twist</span>
                <div
                  class="nd-card__text nd-live-notes nd-playbook-prepare__field nd-richtext nd-richtext--editor"
                  data-playbook-field="twist"
                  data-richtext-editor
                  data-placeholder="Potential twist..."
                  role="textbox"
                  aria-label="Twist"
                ></div>
              </div>

              <div class="nd-playbook__field">
                <span class="nd-playbook__field-label">Possible Outcomes</span>
                <div
                  class="nd-card__text nd-live-notes nd-playbook-prepare__field nd-richtext nd-richtext--editor"
                  data-playbook-field="possibleOutcomes"
                  data-richtext-editor
                  data-placeholder="Likely outcomes and consequences..."
                  role="textbox"
                  aria-label="Possible Outcomes"
                ></div>
              </div>

              <div class="nd-playbook__field">
                <span class="nd-playbook__field-label">Reward</span>
                <div
                  class="nd-card__text nd-live-notes nd-playbook-prepare__field nd-richtext nd-richtext--editor"
                  data-playbook-field="experience"
                  data-richtext-editor
                  data-placeholder="XP, treasure, or narrative reward..."
                  role="textbox"
                  aria-label="Reward"
                ></div>
              </div>

              <div class="nd-playbook__field">
                <span class="nd-playbook__field-label">Scene</span>
                <select class="nd-playbook-prepare__select" data-playbook-scene-select aria-label="Scene"></select>
                <div class="nd-playbook__related nd-playbook-prepare__chips" data-playbook-scene-chips></div>
              </div>

              <div class="nd-playbook__field">
                <span class="nd-playbook__field-label">Characters</span>
                <div class="nd-playbook-prepare__picker-row">
                  <select class="nd-playbook-prepare__select" data-playbook-character-select aria-label="Add character"></select>
                  <button type="button" class="nd-playbook-prepare__add-entity" data-playbook-add-character>
                    Add
                  </button>
                </div>
                <div class="nd-playbook__related nd-playbook-prepare__chips" data-playbook-character-chips></div>
              </div>

              <div class="nd-playbook__field">
                <span class="nd-playbook__field-label">Session Notes</span>
                <div class="nd-richtext-toolbar" data-richtext-toolbar role="toolbar" aria-label="Session Entry formatting">
                  <button type="button" data-richtext-command="bold" aria-label="Bold"><strong>B</strong></button>
                  <button type="button" data-richtext-command="italic" aria-label="Italic"><em>I</em></button>
                  <button type="button" data-richtext-command="underline" aria-label="Underline"><u>U</u></button>
                  <span class="nd-richtext-toolbar__divider" aria-hidden="true"></span>
                  <button type="button" data-richtext-command="heading" data-richtext-value="h2" aria-label="Heading 2">H2</button>
                  <button type="button" data-richtext-command="heading" data-richtext-value="h3" aria-label="Heading 3">H3</button>
                  <span class="nd-richtext-toolbar__divider" aria-hidden="true"></span>
                  <button type="button" data-richtext-command="list" data-richtext-value="ul" aria-label="Bullet list">• List</button>
                  <button type="button" data-richtext-command="list" data-richtext-value="ol" aria-label="Numbered list">1. List</button>
                  <span class="nd-richtext-toolbar__divider" aria-hidden="true"></span>
                  <label class="nd-richtext-toolbar__color">
                    <select data-richtext-color aria-label="Text color">
                      <option value="default">Default</option>
                      <option value="blue">Blue</option>
                      <option value="green">Green</option>
                      <option value="yellow">Yellow</option>
                      <option value="orange">Orange</option>
                      <option value="red">Red</option>
                      <option value="purple">Purple</option>
                      <option value="gray">Gray</option>
                    </select>
                  </label>
                  <button type="button" data-richtext-command="clear" aria-label="Clear formatting">Clear</button>
                </div>
                <div
                  class="nd-card__text nd-live-notes nd-playbook-prepare__field nd-playbook-prepare__field--notes nd-richtext nd-richtext--editor"
                  data-playbook-field="gmNotes"
                  data-richtext-editor
                  data-placeholder="Session-specific notes..."
                  role="textbox"
                  aria-label="Session-specific notes"
                ></div>
              </div>
            </div>
          </div>
        </div>

        <section class="nd-session-import" data-session-import hidden aria-label="Import from Campaign">
          <header class="nd-session-import__header">
            <div>
              <div class="nd-campaign-panel__eyebrow">Session Builder</div>
              <h2>Import from Campaign</h2>
            </div>
            <button type="button" data-close-campaign-import aria-label="Close">×</button>
          </header>
          <div class="nd-session-import__list" data-session-import-list></div>
          <footer>
            <button type="button" data-close-campaign-import>Cancel</button>
            <button type="button" class="nd-campaign-save" data-import-campaign-entries>
              Import Selected
            </button>
          </footer>
        </section>
      </article>
    </section>

  </div>

</div>
