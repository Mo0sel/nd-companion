<div class="nd-companion__shell">

  <nav class="nd-workspace-switcher" aria-label="Workspaces">
    <button
      type="button"
      class="nd-workspace-switcher__button"
      data-action="setWorkspace"
      data-workspace="play"
      aria-pressed="true"
    >Play</button>
    <button
      type="button"
      class="nd-workspace-switcher__button"
      data-action="setWorkspace"
      data-workspace="prepare"
      aria-pressed="false"
    >Prepare</button>
    <button
      type="button"
      class="nd-workspace-switcher__button"
      data-action="setWorkspace"
      data-workspace="notes"
      aria-pressed="false"
    >NPC</button>
  </nav>

  <div class="nd-workspace-region">

    {{!-- PLAY — stable live-session dashboard --}}
    <section class="nd-workspace nd-play" data-workspace-panel="play" aria-label="Play workspace">

      {{!-- Stable campaign header: campaign-level information only --}}
      <div class="nd-play__row nd-play__row--top">
        <section class="nd-play-campaign" data-play-campaign aria-label="Campaign Context">
          <div class="nd-play-campaign__main">
            <div class="nd-play-campaign__title" data-context="campaign-title"></div>
            <div class="nd-play-campaign__location" data-context="scene">
              <span class="nd-play-campaign__location-label">Current Location</span>
              <span class="nd-play-campaign__location-value" data-context-value>No active scene</span>
            </div>
          </div>
        </section>
      </div>

      {{!-- Row 2: Playbook hero --}}
      <div class="nd-play__row nd-play__row--hero">
        <article class="nd-playbook-card" data-playbook aria-label="Playbook">
          <div class="nd-playbook-card__accent" data-playbook="accent" aria-hidden="true"></div>
          <div class="nd-playbook-card__body">
            <header class="nd-playbook-card__header">
              <div class="nd-playbook-card__identity">
                <button type="button" class="nd-playbook-card__nav" data-playbook-nav="prev" aria-label="Previous beat">←</button>
                <div class="nd-playbook-card__counter nd-mono" data-playbook="counter" aria-label="Beat position">
                  <span class="nd-playbook-card__counter-current" data-playbook-counter="current">0</span>
                  <span class="nd-playbook-card__counter-sep">/</span>
                  <span class="nd-playbook-card__counter-total" data-playbook-counter="total">0</span>
                </div>
                <div class="nd-playbook-card__title-block">
                  <div class="nd-playbook-card__eyebrow">Current Beat</div>
                  <h2 class="nd-playbook-card__title" data-playbook="title"></h2>
                </div>
                <button type="button" class="nd-playbook-card__nav" data-playbook-nav="next" aria-label="Next beat">→</button>
              </div>
              <div class="nd-playbook-card__statuses" role="group" aria-label="Beat status">
                <span class="nd-playbook-status" data-playbook-status="planned" aria-pressed="false">Planned</span>
                <span class="nd-playbook-status" data-playbook-status="active" aria-pressed="false">Active</span>
                <span class="nd-playbook-status" data-playbook-status="done" aria-pressed="false">Done</span>
              </div>
            </header>

            <div class="nd-playbook-card__panels">
              <div class="nd-playbook-card__left-column">
                <div class="nd-playbook-panel nd-playbook-panel--objective" data-playbook-field-block="objective">
                  <div class="nd-playbook-panel__label">Objectives</div>
                  <div class="nd-playbook-panel__text nd-richtext" data-playbook="objective"></div>
                </div>
                <div class="nd-playbook-experience" aria-label="Experience reward">
                  <div>
                    <div class="nd-playbook-experience__label">Experience</div>
                    <div class="nd-playbook-experience__hint">Reward</div>
                  </div>
                  <span class="nd-playbook-experience__value">—</span>
                </div>
              </div>
              <div class="nd-playbook-panel nd-playbook-panel--gm-notes" data-playbook-field-block="gmNotes">
                <div class="nd-playbook-panel__label">Beat Notes</div>
                <div class="nd-playbook-panel__text nd-richtext" data-playbook="gmNotes"></div>
              </div>
            </div>

            <div class="nd-playbook-card__related" data-playbook-field-block="entities">
              <div class="nd-playbook-card__related-label">Related</div>
              <div class="nd-playbook-card__chips" data-playbook="entities"></div>
            </div>
          </div>
        </article>
      </div>

      {{!-- Session Notes consume all remaining vertical space --}}
      <div class="nd-play__row nd-play__row--bottom">
        <section class="nd-play-notes" data-live-notes-root aria-label="Session Notes">
          <header class="nd-play-notes__header">
            <span class="nd-play-notes__title">Session Notes</span>
            <div class="nd-play-notes__saved">
              <span class="nd-play-notes__dot" aria-hidden="true"></span>
              <span>auto-saved</span>
              <span class="nd-live-notes__status" data-live-notes-status hidden></span>
            </div>
          </header>
          <div
            class="nd-live-notes nd-play-notes__editor"
            data-storage="sessionNotes"
            data-placeholder="Session Notes..."
            role="textbox"
            aria-label="Session Notes"
          ></div>
        </section>

      </div>
    </section>

    <section class="nd-workspace" data-workspace-panel="notes" aria-label="NPC workspace" hidden>
      <p class="nd-workspace__placeholder">
        NPC dossiers are reserved for future work.
      </p>
    </section>

    <section class="nd-workspace" data-workspace-panel="prepare" aria-label="Prepare workspace" hidden>
      <article class="nd-card nd-card--playbook-prepare" data-playbook-prepare data-live-notes-root aria-label="Playbook prepare">
        <header class="nd-card__header">
          <span class="nd-card__accent" aria-hidden="true"></span>
          <h2 class="nd-card__label">Playbook</h2>
          <span class="nd-live-notes__status" data-live-notes-status hidden></span>
        </header>

        <div class="nd-playbook-prepare">
          <div class="nd-playbook-prepare__sidebar">
            <button type="button" class="nd-playbook-prepare__add" data-playbook-add-beat>
              + Add Beat
            </button>
            <div class="nd-playbook-prepare__list" data-playbook-prepare-list role="list"></div>
          </div>

          <div class="nd-playbook-prepare__main">
            <div class="nd-playbook-prepare__empty" data-playbook-prepare-empty hidden>
              <p class="nd-card__text nd-workspace__placeholder">
                No beats yet. Add a beat to start preparing this session.
              </p>
              <button type="button" class="nd-playbook-prepare__add" data-playbook-add-beat>
                + Add Beat
              </button>
            </div>

            <div class="nd-playbook-prepare__editor" data-playbook-prepare-editor>
              <div class="nd-playbook-prepare__actions">
                <button type="button" class="nd-playbook-prepare__current-button" data-playbook-set-current>
                  Set as Current Beat
                </button>
              </div>

              <div class="nd-richtext-toolbar" data-richtext-toolbar role="toolbar" aria-label="Rich text formatting">
                <button type="button" data-richtext-command="bold" aria-label="Bold"><strong>B</strong></button>
                <button type="button" data-richtext-command="italic" aria-label="Italic"><em>I</em></button>
                <button type="button" data-richtext-command="underline" aria-label="Underline"><u>U</u></button>
                <span class="nd-richtext-toolbar__divider" aria-hidden="true"></span>
                <button type="button" data-richtext-command="heading" data-richtext-value="h2" aria-label="Heading 2">H2</button>
                <button type="button" data-richtext-command="heading" data-richtext-value="h3" aria-label="Heading 3">H3</button>
                <span class="nd-richtext-toolbar__divider" aria-hidden="true"></span>
                <button type="button" data-richtext-command="list" data-richtext-value="ul" aria-label="Bullet list">• List</button>
                <button type="button" data-richtext-command="list" data-richtext-value="ol" aria-label="Numbered list">1. List</button>
                <span class="nd-richtext-toolbar__divider" aria-hidden="true"></span>
                <label class="nd-richtext-toolbar__color">
                  <select data-richtext-color aria-label="Text color">
                    <option value="default">Default</option>
                    <option value="blue">Blue</option>
                    <option value="green">Green</option>
                    <option value="yellow">Yellow</option>
                    <option value="orange">Orange</option>
                    <option value="red">Red</option>
                    <option value="purple">Purple</option>
                    <option value="gray">Gray</option>
                  </select>
                </label>
                <button type="button" data-richtext-command="clear" aria-label="Clear formatting">Clear</button>
              </div>

              <div class="nd-playbook__field">
                <span class="nd-playbook__field-label">Title</span>
                <div
                  class="nd-card__text nd-live-notes nd-playbook-prepare__field"
                  data-playbook-field="title"
                  data-placeholder="Beat title..."
                  role="textbox"
                  aria-label="Beat title"
                ></div>
              </div>

              <div class="nd-playbook__field">
                <span class="nd-playbook__field-label">Objective</span>
                <div
                  class="nd-card__text nd-live-notes nd-playbook-prepare__field nd-richtext nd-richtext--editor"
                  data-playbook-field="objective"
                  data-richtext-editor
                  data-placeholder="Objective..."
                  role="textbox"
                  aria-label="Beat objective"
                ></div>
              </div>

              <div class="nd-playbook__field">
                <span class="nd-playbook__field-label">Scene</span>
                <select class="nd-playbook-prepare__select" data-playbook-scene-select aria-label="Scene"></select>
                <div class="nd-playbook__related nd-playbook-prepare__chips" data-playbook-scene-chips></div>
              </div>

              <div class="nd-playbook__field">
                <span class="nd-playbook__field-label">Characters</span>
                <div class="nd-playbook-prepare__picker-row">
                  <select class="nd-playbook-prepare__select" data-playbook-character-select aria-label="Add character"></select>
                  <button type="button" class="nd-playbook-prepare__add-entity" data-playbook-add-character>
                    Add
                  </button>
                </div>
                <div class="nd-playbook__related nd-playbook-prepare__chips" data-playbook-character-chips></div>
              </div>

              <div class="nd-playbook__field">
                <span class="nd-playbook__field-label">GM Notes</span>
                <div
                  class="nd-card__text nd-live-notes nd-playbook-prepare__field nd-playbook-prepare__field--notes nd-richtext nd-richtext--editor"
                  data-playbook-field="gmNotes"
                  data-richtext-editor
                  data-placeholder="GM notes..."
                  role="textbox"
                  aria-label="GM notes"
                ></div>
              </div>
            </div>
          </div>
        </div>
      </article>
    </section>

  </div>

</div>
