<div class="nd-companion__shell">

  <section class="nd-campaign-context" aria-label="Campaign Context">
    <div class="nd-campaign-context__item" data-context="scene" hidden>
      <span class="nd-campaign-context__label">Scene</span>
      <span class="nd-campaign-context__value" data-context-value></span>
    </div>
    <div class="nd-campaign-context__item" data-context="focus">
      <span class="nd-campaign-context__label">Focus</span>
      <span class="nd-campaign-context__value" data-context-value>Party</span>
    </div>
    <div class="nd-campaign-context__item" data-context="combat" hidden>
      <span class="nd-campaign-context__label">Combat</span>
      <span class="nd-campaign-context__value" data-context-value></span>
    </div>
    <div class="nd-campaign-context__item" data-context="round" hidden>
      <span class="nd-campaign-context__label">Round</span>
      <span class="nd-campaign-context__value" data-context-value></span>
    </div>
    <div class="nd-campaign-context__item" data-context="turn" hidden>
      <span class="nd-campaign-context__label">Turn</span>
      <span class="nd-campaign-context__value" data-context-value></span>
    </div>
  </section>

  <section class="nd-focus-panel" data-focus-panel data-focus-kind="party" aria-label="Focus">
    <img class="nd-focus-panel__portrait" data-focus="portrait" alt="" hidden>
    <div class="nd-focus-panel__meta">
      <div class="nd-focus-panel__name" data-focus="name">Party</div>
      <div class="nd-focus-panel__type" data-focus-row="type" hidden>
        <span class="nd-focus-panel__type-label">Type</span>
        <span class="nd-focus-panel__type-value" data-focus="type"></span>
      </div>
    </div>
  </section>

  <nav class="nd-workspace-switcher" aria-label="Workspaces">
    <button
      type="button"
      class="nd-workspace-switcher__button"
      data-action="setWorkspace"
      data-workspace="play"
      aria-pressed="true"
    >Play</button>
    <button
      type="button"
      class="nd-workspace-switcher__button"
      data-action="setWorkspace"
      data-workspace="notes"
      aria-pressed="false"
    >Notes</button>
    <button
      type="button"
      class="nd-workspace-switcher__button"
      data-action="setWorkspace"
      data-workspace="prepare"
      aria-pressed="false"
    >Prepare</button>
  </nav>

  <div class="nd-workspace-region">

    <section class="nd-workspace" data-workspace-panel="play" aria-label="Play workspace">
      <section class="nd-companion-memory nd-card" data-companion-memory data-live-notes-root aria-label="Companion Memory">
        <header class="nd-card__header">
          <span class="nd-card__accent" aria-hidden="true"></span>
          <h2 class="nd-card__label">Companion Memory</h2>
          <span class="nd-live-notes__status" data-live-notes-status hidden></span>
        </header>
        <p class="nd-companion-memory__empty" data-memory-empty>
          Select an Actor to view Companion Memory.
        </p>
        <div
          class="nd-card__text nd-live-notes"
          data-memory-editor
          data-placeholder="Click here to start typing..."
          role="textbox"
          aria-label="Companion Memory"
          hidden
        ></div>
      </section>

      <article class="nd-card nd-card--threads">
        <header class="nd-card__header">
          <span class="nd-card__accent" aria-hidden="true"></span>
          <h2 class="nd-card__label">Open Threads</h2>
        </header>
        <ul class="nd-thread-list">
          <li class="nd-thread-list__item">
            <span class="nd-thread-list__marker" aria-hidden="true"></span>
            <span class="nd-thread-list__text">Investigate who burned the Millhaven granary</span>
          </li>
          <li class="nd-thread-list__item">
            <span class="nd-thread-list__marker" aria-hidden="true"></span>
            <span class="nd-thread-list__text">Track down the Pale Merchant's ledger</span>
          </li>
          <li class="nd-thread-list__item nd-thread-list__item--done">
            <span class="nd-thread-list__marker" aria-hidden="true"></span>
            <span class="nd-thread-list__text">Return the stolen sextant to Captain Voss</span>
          </li>
          <li class="nd-thread-list__item">
            <span class="nd-thread-list__marker" aria-hidden="true"></span>
            <span class="nd-thread-list__text">Discover why the Thornwood has gone silent</span>
          </li>
          <li class="nd-thread-list__item">
            <span class="nd-thread-list__marker" aria-hidden="true"></span>
            <span class="nd-thread-list__text">Deliver the letter to Sister Elara in Ashfeld</span>
          </li>
        </ul>
      </article>

      <footer class="nd-companion__footer">
        <button type="button" class="nd-oh-shit-button">
          <span class="nd-oh-shit-button__icon" aria-hidden="true">⚠</span>
          OH SHIT!
        </button>
      </footer>
    </section>

    <section class="nd-workspace" data-workspace-panel="notes" aria-label="Notes workspace" hidden>
      <article class="nd-card nd-card--session-notes" data-live-notes-root aria-label="Session Notes">
        <header class="nd-card__header">
          <span class="nd-card__accent" aria-hidden="true"></span>
          <h2 class="nd-card__label">Session Notes</h2>
          <span class="nd-live-notes__status" data-live-notes-status hidden></span>
        </header>
        <div
          class="nd-card__text nd-live-notes nd-live-notes--session"
          data-storage="sessionNotes"
          data-placeholder="Session Notes..."
          role="textbox"
          aria-label="Session Notes"
        ></div>
      </article>

      <article class="nd-card nd-card--playbook" data-playbook aria-label="Playbook">
        <header class="nd-card__header nd-playbook__header">
          <span class="nd-card__accent" aria-hidden="true"></span>
          <h2 class="nd-card__label">Playbook</h2>
          <div class="nd-playbook__nav" aria-label="Beat navigation">
            <button type="button" class="nd-playbook__nav-button" data-playbook-nav="prev" aria-label="Previous beat">
              ◀
            </button>
            <span class="nd-playbook__counter" data-playbook="counter">3 / 7</span>
            <button type="button" class="nd-playbook__nav-button" data-playbook-nav="next" aria-label="Next beat">
              ▶
            </button>
          </div>
        </header>

        <h3 class="nd-playbook__title" data-playbook="title"></h3>

        <div class="nd-playbook__field" data-playbook-field-block="objective">
          <span class="nd-playbook__field-label">Objective</span>
          <p class="nd-card__text" data-playbook="objective"></p>
        </div>

        <div class="nd-playbook__field" data-playbook-field-block="scene">
          <span class="nd-playbook__field-label">Scene</span>
          <div class="nd-playbook__related" data-playbook="scene"></div>
        </div>

        <div class="nd-playbook__field" data-playbook-field-block="characters">
          <span class="nd-playbook__field-label">Characters</span>
          <div class="nd-playbook__related" data-playbook="characters"></div>
        </div>

        <div class="nd-playbook__field" data-playbook-field-block="gmNotes">
          <span class="nd-playbook__field-label">GM Notes</span>
          <p class="nd-card__text" data-playbook="gmNotes"></p>
        </div>

        <div class="nd-playbook__field" data-playbook-related hidden>
          <span class="nd-playbook__field-label">Related</span>
          <div class="nd-playbook__related" data-playbook="related"></div>
        </div>
      </article>
    </section>

    <section class="nd-workspace" data-workspace-panel="prepare" aria-label="Prepare workspace" hidden>
      <article class="nd-card nd-card--playbook-prepare" data-playbook-prepare data-live-notes-root aria-label="Playbook prepare">
        <header class="nd-card__header">
          <span class="nd-card__accent" aria-hidden="true"></span>
          <h2 class="nd-card__label">Playbook</h2>
          <span class="nd-live-notes__status" data-live-notes-status hidden></span>
        </header>

        <div class="nd-playbook-prepare">
          <div class="nd-playbook-prepare__sidebar">
            <button type="button" class="nd-playbook-prepare__add" data-playbook-add-beat>
              + Add Beat
            </button>
            <div class="nd-playbook-prepare__list" data-playbook-prepare-list role="list"></div>
          </div>

          <div class="nd-playbook-prepare__main">
            <div class="nd-playbook-prepare__empty" data-playbook-prepare-empty hidden>
              <p class="nd-card__text nd-workspace__placeholder">
                No beats yet. Add a beat to start preparing this session.
              </p>
              <button type="button" class="nd-playbook-prepare__add" data-playbook-add-beat>
                + Add Beat
              </button>
            </div>

            <div class="nd-playbook-prepare__editor" data-playbook-prepare-editor>
              <div class="nd-playbook-prepare__actions">
                <button type="button" class="nd-playbook-prepare__current-button" data-playbook-set-current>
                  Set as Current Beat
                </button>
              </div>

              <div class="nd-playbook__field">
                <span class="nd-playbook__field-label">Title</span>
                <div
                  class="nd-card__text nd-live-notes nd-playbook-prepare__field"
                  data-playbook-field="title"
                  data-placeholder="Beat title..."
                  role="textbox"
                  aria-label="Beat title"
                ></div>
              </div>

              <div class="nd-playbook__field">
                <span class="nd-playbook__field-label">Objective</span>
                <div
                  class="nd-card__text nd-live-notes nd-playbook-prepare__field"
                  data-playbook-field="objective"
                  data-placeholder="Objective..."
                  role="textbox"
                  aria-label="Beat objective"
                ></div>
              </div>

              <div class="nd-playbook__field">
                <span class="nd-playbook__field-label">Scene</span>
                <select class="nd-playbook-prepare__select" data-playbook-scene-select aria-label="Scene"></select>
                <div class="nd-playbook__related nd-playbook-prepare__chips" data-playbook-scene-chips></div>
              </div>

              <div class="nd-playbook__field">
                <span class="nd-playbook__field-label">Characters</span>
                <div class="nd-playbook-prepare__picker-row">
                  <select class="nd-playbook-prepare__select" data-playbook-character-select aria-label="Add character"></select>
                  <button type="button" class="nd-playbook-prepare__add-entity" data-playbook-add-character>
                    Add
                  </button>
                </div>
                <div class="nd-playbook__related nd-playbook-prepare__chips" data-playbook-character-chips></div>
              </div>

              <div class="nd-playbook__field">
                <span class="nd-playbook__field-label">GM Notes</span>
                <div
                  class="nd-card__text nd-live-notes nd-playbook-prepare__field nd-playbook-prepare__field--notes"
                  data-playbook-field="gmNotes"
                  data-placeholder="GM notes..."
                  role="textbox"
                  aria-label="GM notes"
                ></div>
              </div>
            </div>
          </div>
        </div>
      </article>
    </section>

  </div>

</div>
