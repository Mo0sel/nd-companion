<div class="nd-companion__shell">

  <header class="nd-global-header">
    <div class="nd-global-header__brand">
      <div class="nd-global-header__logo" aria-hidden="true">N</div>
      <div class="nd-global-header__brand-text">
        <div class="nd-global-header__title">N&amp;D Companion</div>
        <div class="nd-global-header__subtitle">Foundry VTT · GM Tools</div>
      </div>
    </div>
    <div class="nd-global-header__divider" aria-hidden="true"></div>
    <div class="nd-global-search" data-global-search>
      <span class="nd-global-search__icon" aria-hidden="true">⌕</span>
      <input
        type="search"
        data-global-search-input
        placeholder="Search campaign..."
        aria-label="Search campaign"
        aria-controls="nd-global-search-results"
        aria-expanded="false"
        autocomplete="off"
      >
      <kbd>Ctrl K</kbd>
      <div
        id="nd-global-search-results"
        class="nd-global-search__results"
        data-global-search-results
        role="listbox"
        hidden
      ></div>
    </div>
    <div class="nd-global-header__spacer" aria-hidden="true"></div>
    <div class="nd-session-badge" data-session-badge>
      <span class="nd-session-badge__dot" aria-hidden="true"></span>
      <span data-session-badge-label>Session 1 · Live</span>
    </div>
  </header>

  <nav class="nd-workspace-switcher" aria-label="Workspaces">
    <button
      type="button"
      class="nd-workspace-switcher__button"
      data-action="setWorkspace"
      data-workspace="play"
      aria-pressed="true"
    ><span class="nd-workspace-switcher__icon" aria-hidden="true">▶</span>Play</button>
    <button
      type="button"
      class="nd-workspace-switcher__button"
      data-action="setWorkspace"
      data-workspace="prepare"
      aria-pressed="false"
    ><span class="nd-workspace-switcher__icon" aria-hidden="true">✦</span>Prepare</button>
    <button
      type="button"
      class="nd-workspace-switcher__button"
      data-action="setWorkspace"
      data-workspace="campaign"
      aria-pressed="false"
    ><span class="nd-workspace-switcher__icon" aria-hidden="true">⬡</span>Campaign</button>
    <button
      type="button"
      class="nd-workspace-switcher__button"
      data-action="setWorkspace"
      data-workspace="notes"
      aria-pressed="false"
    ><span class="nd-workspace-switcher__icon" aria-hidden="true">◎</span>Actors</button>
  </nav>

  <div class="nd-workspace-region">

    {{!-- PLAY — stable live-session dashboard (design/current PlayWorkspace) --}}
    <section class="nd-workspace nd-play" data-workspace-panel="play" data-playbook aria-label="Play workspace">

      {{!-- Context bar: campaign-level information + entry status --}}
      <div class="nd-play-context" data-play-campaign aria-label="Campaign Context">
        <div class="nd-play-context__campaign">
          <span class="nd-play-context__eyebrow">Campaign</span>
          <span class="nd-play-context__name" data-context="campaign-title"></span>
        </div>
        <div class="nd-play-context__divider" aria-hidden="true"></div>
        <div class="nd-play-context__chip nd-play-context__chip--scene" data-context="scene">
          <span class="nd-play-context__pin" aria-hidden="true">◆</span>
          <span data-context-value>No active scene</span>
        </div>
        <div class="nd-play-context__chip nd-play-context__chip--focus">
          <span class="nd-play-context__avatar" data-focus="initials" aria-hidden="true">P</span>
          <span data-focus="name">Party</span>
        </div>
        <div class="nd-play-context__spacer" aria-hidden="true"></div>
        <div class="nd-entry-status" data-playbook-state data-state="active" role="status" aria-label="Entry status">
          <span class="nd-entry-status__pill nd-entry-status__pill--active">Active</span>
          <span class="nd-entry-status__pill nd-entry-status__pill--done">Completed</span>
        </div>
      </div>

      {{!-- Entry navigation --}}
      <div class="nd-play-entry-nav" aria-label="Entry navigation">
        <span class="nd-play-entry-nav__accent" data-playbook="accent" aria-hidden="true"></span>
        <button type="button" class="nd-button nd-button--nav" data-playbook-nav="prev" aria-label="Previous entry">←</button>
        <div class="nd-play-entry-nav__meta">
          <span class="nd-play-entry-nav__counter nd-mono" data-playbook="counter" aria-label="Entry position">
            <span class="nd-play-entry-nav__counter-current" data-playbook-counter="current">0</span>
            <span class="nd-play-entry-nav__counter-sep">/</span>
            <span class="nd-play-entry-nav__counter-total" data-playbook-counter="total">0</span>
          </span>
          <span class="nd-play-entry-nav__eyebrow">Current Entry</span>
          <h2 class="nd-play-entry-nav__title" data-playbook="title"></h2>
        </div>
        <button type="button" class="nd-button nd-button--nav" data-playbook-nav="next" aria-label="Next entry">→</button>
      </div>

      {{!-- Scrollable dashboard content --}}
      <div class="nd-play-content">

        {{!-- Scene Flow group --}}
        <h3 class="nd-play-section-title nd-play-section-title--scene-flow">Scene Flow</h3>
        <div class="nd-play-entry-grid nd-play-entry-grid--scene-flow">

          <section class="nd-play-card" data-playbook-field-block="speechNotes">
            <div class="nd-play-card__labelrow">
              <span class="nd-play-card__label">Speech Notes</span>
            </div>
            <div
              class="nd-play-card__content nd-richtext nd-play-inline-editor"
              data-playbook="speechNotes"
              data-placeholder="Dialogue, read-aloud text..."
              role="textbox"
              aria-label="Speech Notes"
            ></div>
          </section>

          <details class="nd-play-card nd-play-card--setup" data-playbook-field-block="setup" open>
            <summary>
              <span class="nd-play-card__labelrow">
                <span class="nd-play-card__label">Setup</span>
              </span>
              <span class="nd-play-card__collapse-label">Collapse</span>
            </summary>
            <div class="nd-play-card__content nd-richtext" data-playbook="setup"></div>
            <div class="nd-play-card__references" data-playbook-field-block="entities">
              <div class="nd-playbook-card__chips" data-playbook="entities"></div>
            </div>
          </details>

          <section class="nd-play-card" data-playbook-field-block="objective">
            <div class="nd-play-card__labelrow">
              <span class="nd-play-card__label">Objectives</span>
              <button type="button" class="nd-play-card__action" data-objective-add aria-label="Add objective">+ Add</button>
            </div>
            <div
              class="nd-play-card__content nd-richtext nd-play-inline-editor nd-play-objectives"
              data-playbook="objective"
              data-placeholder="Add an objective..."
              role="textbox"
              aria-label="Objectives"
            ></div>
          </section>

          <section class="nd-play-card" data-playbook-field-block="experience">
            <div class="nd-play-card__labelrow">
              <span class="nd-play-card__label">Experience &amp; Reward</span>
            </div>
            <div
              class="nd-play-card__content nd-richtext nd-play-inline-editor"
              data-playbook="experience"
              data-placeholder="Not set."
              role="textbox"
              aria-label="Experience"
            ></div>
          </section>
        </div>

        {{!-- Response & Notes group --}}
        <h3 class="nd-play-section-title nd-play-section-title--response">Response &amp; Notes</h3>
        <div class="nd-play-entry-grid nd-play-entry-grid--response">

          <section class="nd-play-card" data-playbook-field-block="twist">
            <div class="nd-play-card__labelrow">
              <span class="nd-play-card__label">Twist</span>
            </div>
            <div class="nd-play-card__content nd-richtext" data-playbook="twist"></div>
          </section>

          <section class="nd-play-card" data-playbook-field-block="possibleOutcomes">
            <div class="nd-play-card__labelrow">
              <span class="nd-play-card__label">Possible Outcomes</span>
            </div>
            <div class="nd-play-card__content nd-richtext" data-playbook="possibleOutcomes"></div>
          </section>

          <section class="nd-play-card nd-play-card--wide" data-playbook-field-block="gmNotes">
            <div class="nd-play-card__labelrow">
              <span class="nd-play-card__label">GM Notes</span>
              <span class="nd-play-card__live-dot" aria-hidden="true"></span>
            </div>
            <div
              class="nd-play-card__content nd-richtext nd-play-inline-editor"
              data-playbook="gmNotes"
              data-placeholder="Live GM notes for this entry..."
              role="textbox"
              aria-label="Entry Notes"
            ></div>
          </section>
        </div>

        {{!-- Session strip --}}
        <div class="nd-play-session-strip">
          <section
            class="nd-play-notes"
            data-live-notes-root
            data-resizable-panel="play-session-notes"
            data-resize-min="120"
            aria-label="Session Notes"
          >
            <header class="nd-play-notes__header">
              <span class="nd-play-notes__title">Session Notes</span>
              <div class="nd-play-notes__saved">
                <span class="nd-play-notes__dot" aria-hidden="true"></span>
                <span>auto-saved</span>
                <span class="nd-live-notes__status" data-live-notes-status hidden></span>
              </div>
            </header>
            <div
              class="nd-live-notes nd-play-notes__editor nd-richtext"
              data-storage="sessionNotes"
              data-storage-html
              data-placeholder="Session Notes..."
              role="textbox"
              aria-label="Session Notes"
            ></div>
          </section>

          <section
            class="nd-play-notes nd-play-log"
            data-live-notes-root
            data-resizable-panel="play-session-log"
            data-resize-min="120"
            aria-label="Session Log"
          >
            <header class="nd-play-notes__header">
              <span class="nd-play-notes__title">Session Log</span>
              <div class="nd-play-notes__saved">
                <span class="nd-play-notes__dot" aria-hidden="true"></span>
                <span>auto-saved</span>
                <span class="nd-live-notes__status" data-live-notes-status hidden></span>
              </div>
            </header>
            <div
              class="nd-live-notes nd-play-notes__editor nd-richtext"
              data-storage="sessionLog"
              data-placeholder="Record what happened this session..."
              role="textbox"
              aria-label="Session Log"
            ></div>
          </section>
        </div>

        <div class="nd-play-end-session">
          <button type="button" class="nd-play-end-session__button" data-end-session>
            <span aria-hidden="true">🏁</span>
            End Session
          </button>
        </div>
      </div>
    </section>

    {{!-- CAMPAIGN — lightweight Session and Thread database --}}
    <section
      class="nd-workspace nd-campaign"
      data-workspace-panel="campaign"
      data-campaign-workspace
      aria-label="Campaign workspace"
      hidden
    >
      <div class="nd-quest-layout">
        <aside class="nd-quest-sidebar" aria-label="Quest navigation">
          <div class="nd-quest-sidebar__head">
            <div class="nd-quest-sidebar__title">Campaign</div>
            <p class="nd-quest-sidebar__session" data-campaign-current-session>Session 1</p>
            <nav class="nd-campaign-nav" aria-label="Campaign sections">
              <button type="button" class="is-active" data-campaign-section="quests">Quests</button>
              <button type="button" data-campaign-section="actors">Actors</button>
              <button type="button" data-campaign-section="locations">Locations</button>
              <button type="button" data-campaign-section="items">Items</button>
              <button type="button" data-campaign-section="chronicle">Chronicle</button>
            </nav>
          </div>

          <div class="nd-quest-sidebar__scroll">
            <div data-campaign-nav-panel="quests">
              <div class="nd-quest-sidebar__section" data-quest-category="MAIN">
                <div class="nd-quest-sidebar__heading">
                  <span>Main Quests</span>
                  <button type="button" data-new-quest="MAIN" aria-label="New Main Quest">+</button>
                </div>
                <div data-quest-list="MAIN"></div>
              </div>
              <div class="nd-quest-sidebar__section" data-quest-category="SIDE">
                <div class="nd-quest-sidebar__heading">
                  <span>Side Quests</span>
                  <button type="button" data-new-quest="SIDE" aria-label="New Side Quest">+</button>
                </div>
                <div data-quest-list="SIDE"></div>
              </div>
              <div class="nd-quest-sidebar__section" data-quest-category="COMPANION">
                <div class="nd-quest-sidebar__heading">
                  <span>Companion Quests</span>
                  <button type="button" data-new-quest="COMPANION" aria-label="New Companion Quest">+</button>
                </div>
                <div data-quest-list="COMPANION"></div>
              </div>
            </div>

            <div data-campaign-nav-panel="entities" hidden>
              <div class="nd-quest-sidebar__section">
                <div class="nd-quest-sidebar__heading">
                  <span data-campaign-entity-heading>Actors</span>
                </div>
                <div data-campaign-entity-list></div>
              </div>
            </div>

            <div
              class="nd-quest-sidebar__section nd-quest-sidebar__section--memory"
              data-campaign-nav-panel="chronicle"
              hidden
            >
              <div class="nd-quest-sidebar__heading nd-quest-sidebar__heading--memory">
                <span>Chronicle</span>
              </div>
              <button type="button" class="nd-memory-import-open" data-open-memory-import>
                Import Session
              </button>
              <div data-memory-list></div>
            </div>
          </div>
        </aside>

        <main class="nd-quest-panel">
          <div class="nd-quest-empty" data-quest-empty>
            Select a Quest or create one to begin writing your campaign.
          </div>

          <section data-quest-editor hidden>
            <header class="nd-campaign-panel__header">
              <div class="nd-campaign-panel__headline">
                <div class="nd-campaign-panel__eyebrow" data-quest-eyebrow>Campaign Quest</div>
                <input class="nd-quest-title-input" type="text" data-quest-title placeholder="Quest title">
              </div>
              <div class="nd-campaign-panel__meta">
                <span class="nd-campaign-save-status" data-quest-saved hidden></span>
                <label class="nd-campaign-field nd-campaign-field--compact">
                  <span>Status</span>
                  <select data-quest-status>
                    <option value="OPEN">OPEN</option>
                    <option value="ACTIVE">ACTIVE</option>
                    <option value="RESOLVED">RESOLVED</option>
                  </select>
                </label>
                <label class="nd-campaign-field nd-campaign-field--compact">
                  <span>Category</span>
                  <select data-quest-category>
                    <option value="MAIN">MAIN QUEST</option>
                    <option value="SIDE">SIDE QUEST</option>
                    <option value="COMPANION">COMPANION QUEST</option>
                  </select>
                </label>
              </div>
            </header>

            <div class="nd-campaign-field nd-campaign-field--notes">
              <span>Overview</span>
              <div class="nd-richtext-toolbar" data-richtext-toolbar role="toolbar" aria-label="Quest formatting">
                <button type="button" data-richtext-command="bold" aria-label="Bold"><strong>B</strong></button>
                <button type="button" data-richtext-command="italic" aria-label="Italic"><em>I</em></button>
                <button type="button" data-richtext-command="underline" aria-label="Underline"><u>U</u></button>
                <span class="nd-richtext-toolbar__divider" aria-hidden="true"></span>
                <button type="button" data-richtext-command="heading" data-richtext-value="h2" aria-label="Heading 2">H2</button>
                <button type="button" data-richtext-command="heading" data-richtext-value="h3" aria-label="Heading 3">H3</button>
                <button type="button" data-richtext-command="list" data-richtext-value="ul" aria-label="Bullet list">• List</button>
                <button type="button" data-richtext-command="list" data-richtext-value="ol" aria-label="Numbered list">1. List</button>
                <label class="nd-richtext-toolbar__color">
                  <select data-richtext-color aria-label="Text color">
                    <option value="default">Default</option>
                    <option value="blue">Blue</option>
                    <option value="green">Green</option>
                    <option value="yellow">Yellow</option>
                    <option value="orange">Orange</option>
                    <option value="red">Red</option>
                    <option value="purple">Purple</option>
                    <option value="gray">Gray</option>
                  </select>
                </label>
                <button type="button" data-richtext-command="clear" aria-label="Clear formatting">Clear</button>
              </div>
              <div
                class="nd-richtext nd-richtext--editor nd-quest-overview"
                data-quest-overview
                data-richtext-editor
                contenteditable="true"
                data-placeholder="Write the long-form campaign overview..."
              ></div>
            </div>

            <div class="nd-quest-actions">
              <button type="button" class="nd-campaign-save" data-save-quest>Save Quest</button>
            </div>

            <section class="nd-quest-entries">
              <header>
                <div>
                  <div class="nd-campaign-panel__eyebrow nd-hierarchy-context">Playable Content</div>
                  <h3 class="nd-hierarchy-group">Quest Entries</h3>
                </div>
                <button type="button" class="nd-campaign-new-thread" data-add-quest-entry>
                  + New Entry
                </button>
              </header>
              <div data-quest-entry-list></div>
            </section>

            <section class="nd-object-history" data-quest-history hidden aria-label="Quest history">
              <header>
                <div class="nd-campaign-panel__eyebrow nd-hierarchy-context">Campaign Memory</div>
                <h3 class="nd-hierarchy-group">History</h3>
              </header>
              <dl class="nd-object-history__meta">
                <div>
                  <dt>First Seen</dt>
                  <dd data-quest-history-first>—</dd>
                </div>
                <div>
                  <dt>Last Seen</dt>
                  <dd data-quest-history-last>—</dd>
                </div>
                <div>
                  <dt>Appeared In</dt>
                  <dd data-quest-history-count>0</dd>
                </div>
              </dl>
              <div class="nd-object-history__list" data-quest-history-list></div>
            </section>
          </section>

          <section data-campaign-entity-view hidden aria-label="Campaign object history">
            <header class="nd-campaign-panel__header">
              <div class="nd-campaign-panel__headline">
                <div class="nd-campaign-panel__eyebrow">Campaign Memory</div>
                <h2 class="nd-hierarchy-primary" data-campaign-entity-title>Object</h2>
              </div>
            </header>
            <section class="nd-object-history" data-campaign-entity-history hidden>
              <dl class="nd-object-history__meta">
                <div>
                  <dt>First Seen</dt>
                  <dd data-entity-history-first>—</dd>
                </div>
                <div>
                  <dt>Last Seen</dt>
                  <dd data-entity-history-last>—</dd>
                </div>
                <div>
                  <dt>Appeared In</dt>
                  <dd data-entity-history-count>0 sessions</dd>
                </div>
              </dl>
              <div class="nd-object-history__list" data-entity-history-list></div>
            </section>
          </section>

          <section data-memory-view hidden aria-label="Chronicle session">
            <header class="nd-campaign-panel__header">
              <div class="nd-campaign-panel__headline">
                <div class="nd-campaign-panel__eyebrow">Chronicle</div>
                <h2 class="nd-hierarchy-primary" data-memory-title>Session</h2>
              </div>
              <span class="nd-campaign-status" data-memory-source>Imported</span>
            </header>
            <section class="nd-campaign-content-block nd-chronicle-log">
              <h3 class="nd-hierarchy-group">Session Log</h3>
              <textarea data-memory-session-log rows="12" aria-label="Session Log"></textarea>
              <div class="nd-quest-actions">
                <button type="button" class="nd-campaign-save" data-save-memory-log>
                  Save &amp; Refresh Links
                </button>
              </div>
            </section>
            <section class="nd-campaign-content-block">
              <h3 class="nd-hierarchy-group">Detected Relationships</h3>
              <div class="nd-chronicle-relationships">
                <div><strong>Actors</strong><div data-memory-related="actor"></div></div>
                <div><strong>Locations</strong><div data-memory-related="scene"></div></div>
                <div><strong>Items</strong><div data-memory-related="item"></div></div>
                <div><strong>Quests</strong><div data-memory-related="quest"></div></div>
                <div><strong>Quest Entries</strong><div data-memory-related="beat"></div></div>
              </div>
            </section>
          </section>
        </main>
      </div>

      <section class="nd-memory-import" data-memory-import hidden aria-label="Import historical session">
        <header class="nd-memory-import__header">
          <div>
            <div class="nd-campaign-panel__eyebrow">Chronicle</div>
            <h2>Import Session</h2>
          </div>
          <button type="button" data-close-memory-import aria-label="Close">×</button>
        </header>
        <div class="nd-memory-import__fields">
          <label class="nd-campaign-field">
            <span>Session Number</span>
            <input type="number" min="1" step="1" data-memory-import-number placeholder="6" required>
          </label>
          <label class="nd-campaign-field">
            <span>Title <small>Optional</small></span>
            <input type="text" data-memory-import-title placeholder="Karlov Manor">
          </label>
          <label class="nd-campaign-field nd-campaign-field--wide">
            <span>Session Log</span>
            <textarea
              data-memory-import-log
              rows="10"
              placeholder="Paste the Session Log. Use @names or full Actor, Quest, Location, and Item names."
            ></textarea>
          </label>
        </div>
        <footer>
          <button type="button" data-close-memory-import>Cancel</button>
          <button type="button" class="nd-campaign-save" data-import-memory-session>
            Import Session
          </button>
        </footer>
      </section>

    </section>

    <section class="nd-workspace" data-workspace-panel="notes" aria-label="Actors workspace" hidden>
      <div class="nd-actors-grid">
        <section class="nd-companion-memory-card nd-card" data-companion-memory data-live-notes-root aria-label="Companion Memory">
          <header class="nd-card__header">
            <span class="nd-card__accent" aria-hidden="true"></span>
            <h2 class="nd-card__label">Companion Memory</h2>
            <span class="nd-companion-memory-card__actor">
              <span class="nd-hierarchy-context">Focused Actor</span>
              <strong class="nd-companion-memory-card__focus nd-hierarchy-primary" data-focus="name">Party</strong>
            </span>
            <span class="nd-live-notes__status" data-live-notes-status hidden></span>
          </header>
          <div class="nd-companion-memory-card__body">
            <p class="nd-companion-memory__empty" data-memory-empty>
              Select an Actor to view Companion Memory.
            </p>
            <div class="nd-richtext-toolbar" data-richtext-toolbar data-memory-toolbar role="toolbar" aria-label="Companion Memory formatting" hidden>
              <button type="button" data-richtext-command="bold" aria-label="Bold"><strong>B</strong></button>
              <button type="button" data-richtext-command="italic" aria-label="Italic"><em>I</em></button>
              <button type="button" data-richtext-command="underline" aria-label="Underline"><u>U</u></button>
              <span class="nd-richtext-toolbar__divider" aria-hidden="true"></span>
              <button type="button" data-richtext-command="heading" data-richtext-value="h2">H2</button>
              <button type="button" data-richtext-command="heading" data-richtext-value="h3">H3</button>
              <button type="button" data-richtext-command="list" data-richtext-value="ul">• List</button>
              <button type="button" data-richtext-command="list" data-richtext-value="ol">1. List</button>
              <button type="button" data-richtext-command="clear">Clear</button>
            </div>
            <div
              class="nd-card__text nd-live-notes nd-companion-memory-card__editor nd-richtext nd-richtext--editor"
              data-memory-editor
              data-richtext-editor
              data-placeholder="Record everything the Companion permanently knows..."
              role="textbox"
              aria-label="Companion Memory"
              hidden
            ></div>
            <section class="nd-object-history nd-object-history--compact" data-actor-history hidden aria-label="Actor history">
              <header>
                <div class="nd-campaign-panel__eyebrow nd-hierarchy-context">Campaign Memory</div>
                <h3 class="nd-hierarchy-group">History</h3>
              </header>
              <dl class="nd-object-history__meta">
                <div>
                  <dt>First Seen</dt>
                  <dd data-actor-history-first>—</dd>
                </div>
                <div>
                  <dt>Last Seen</dt>
                  <dd data-actor-history-last>—</dd>
                </div>
                <div>
                  <dt>Appeared In</dt>
                  <dd data-actor-history-count>0</dd>
                </div>
              </dl>
              <div class="nd-object-history__list" data-actor-history-list></div>
            </section>
          </div>
        </section>

        <section class="nd-reputation-card nd-card" aria-label="Reputation">
          <header class="nd-card__header">
            <span class="nd-card__accent" aria-hidden="true"></span>
            <h2 class="nd-card__label">Reputation</h2>
          </header>
          <div class="nd-reputation-card__empty">
            <strong>No reputation network yet.</strong>
            <span>Relationships and social connections will appear here in a future update.</span>
          </div>
        </section>
      </div>
    </section>

    <section class="nd-workspace" data-workspace-panel="prepare" aria-label="Prepare workspace" hidden>
      <article class="nd-card nd-card--playbook-prepare" data-playbook-prepare data-live-notes-root aria-label="Session Builder">
        <div class="nd-playbook-prepare">
          <div class="nd-playbook-prepare__main">
            <header class="nd-card__header nd-playbook-prepare__heading">
              <span class="nd-card__accent" aria-hidden="true"></span>
              <h2 class="nd-card__label">Session Builder</h2>
              <span class="nd-live-notes__status" data-live-notes-status hidden></span>
            </header>

            <div class="nd-playbook-prepare__empty" data-playbook-prepare-empty hidden>
              <p class="nd-card__text nd-workspace__placeholder">
                No entries yet. Import from Campaign or add an entry.
              </p>
              <button type="button" class="nd-playbook-prepare__add" data-playbook-add-beat>
                + Add Entry
              </button>
            </div>

            <div class="nd-playbook-prepare__editor" data-playbook-prepare-editor>
              <div class="nd-playbook__field nd-playbook-prepare__title-field">
                <div
                  class="nd-card__text nd-live-notes nd-playbook-prepare__field nd-playbook-prepare__title"
                  data-playbook-field="title"
                  data-placeholder="Entry title..."
                  role="textbox"
                  aria-label="Entry title"
                ></div>
                <button type="button" class="nd-playbook-prepare__current-button" data-playbook-set-current>
                  Set as Current Entry
                </button>
              </div>

              <div class="nd-playbook__field">
                <span class="nd-playbook__field-label">Speech Notes</span>
                <div
                  class="nd-card__text nd-live-notes nd-playbook-prepare__field nd-richtext nd-richtext--editor"
                  data-playbook-field="speechNotes"
                  data-richtext-editor
                  data-placeholder="Dialogue, read-aloud text, and talking points..."
                  role="textbox"
                  aria-label="Speech Notes"
                ></div>
              </div>

              <div class="nd-playbook__field">
                <span class="nd-playbook__field-label">Objective</span>
                <div
                  class="nd-card__text nd-live-notes nd-playbook-prepare__field nd-richtext nd-richtext--editor"
                  data-playbook-field="objective"
                  data-richtext-editor
                  data-placeholder="Objective..."
                  role="textbox"
                  aria-label="Entry objective"
                ></div>
              </div>

              <div class="nd-playbook__field">
                <span class="nd-playbook__field-label">Setup</span>
                <div
                  class="nd-card__text nd-live-notes nd-playbook-prepare__field nd-richtext nd-richtext--editor"
                  data-playbook-field="setup"
                  data-richtext-editor
                  data-placeholder="Scene setup..."
                  role="textbox"
                  aria-label="Setup"
                ></div>
              </div>

              <div class="nd-playbook__field">
                <span class="nd-playbook__field-label">Twist</span>
                <div
                  class="nd-card__text nd-live-notes nd-playbook-prepare__field nd-richtext nd-richtext--editor"
                  data-playbook-field="twist"
                  data-richtext-editor
                  data-placeholder="Potential twist..."
                  role="textbox"
                  aria-label="Twist"
                ></div>
              </div>

              <div class="nd-playbook__field">
                <span class="nd-playbook__field-label">Possible Outcomes</span>
                <div
                  class="nd-card__text nd-live-notes nd-playbook-prepare__field nd-richtext nd-richtext--editor"
                  data-playbook-field="possibleOutcomes"
                  data-richtext-editor
                  data-placeholder="Likely outcomes and consequences..."
                  role="textbox"
                  aria-label="Possible Outcomes"
                ></div>
              </div>

              <div class="nd-playbook__field">
                <span class="nd-playbook__field-label">Reward</span>
                <div
                  class="nd-card__text nd-live-notes nd-playbook-prepare__field nd-richtext nd-richtext--editor"
                  data-playbook-field="experience"
                  data-richtext-editor
                  data-placeholder="XP, treasure, or narrative reward..."
                  role="textbox"
                  aria-label="Reward"
                ></div>
              </div>

              <div class="nd-playbook__field">
                <span class="nd-playbook__field-label">Scene</span>
                <select class="nd-playbook-prepare__select" data-playbook-scene-select aria-label="Scene"></select>
                <div class="nd-playbook__related nd-playbook-prepare__chips" data-playbook-scene-chips></div>
              </div>

              <div class="nd-playbook__field">
                <span class="nd-playbook__field-label">Characters</span>
                <div class="nd-playbook-prepare__picker-row">
                  <select class="nd-playbook-prepare__select" data-playbook-character-select aria-label="Add character"></select>
                  <button type="button" class="nd-playbook-prepare__add-entity" data-playbook-add-character>
                    Add
                  </button>
                </div>
                <div class="nd-playbook__related nd-playbook-prepare__chips" data-playbook-character-chips></div>
              </div>

              <div class="nd-playbook__field">
                <span class="nd-playbook__field-label">Session Notes</span>
                <div class="nd-richtext-toolbar" data-richtext-toolbar role="toolbar" aria-label="Session Entry formatting">
                  <button type="button" data-richtext-command="bold" aria-label="Bold"><strong>B</strong></button>
                  <button type="button" data-richtext-command="italic" aria-label="Italic"><em>I</em></button>
                  <button type="button" data-richtext-command="underline" aria-label="Underline"><u>U</u></button>
                  <span class="nd-richtext-toolbar__divider" aria-hidden="true"></span>
                  <button type="button" data-richtext-command="heading" data-richtext-value="h2" aria-label="Heading 2">H2</button>
                  <button type="button" data-richtext-command="heading" data-richtext-value="h3" aria-label="Heading 3">H3</button>
                  <span class="nd-richtext-toolbar__divider" aria-hidden="true"></span>
                  <button type="button" data-richtext-command="list" data-richtext-value="ul" aria-label="Bullet list">• List</button>
                  <button type="button" data-richtext-command="list" data-richtext-value="ol" aria-label="Numbered list">1. List</button>
                  <span class="nd-richtext-toolbar__divider" aria-hidden="true"></span>
                  <label class="nd-richtext-toolbar__color">
                    <select data-richtext-color aria-label="Text color">
                      <option value="default">Default</option>
                      <option value="blue">Blue</option>
                      <option value="green">Green</option>
                      <option value="yellow">Yellow</option>
                      <option value="orange">Orange</option>
                      <option value="red">Red</option>
                      <option value="purple">Purple</option>
                      <option value="gray">Gray</option>
                    </select>
                  </label>
                  <button type="button" data-richtext-command="clear" aria-label="Clear formatting">Clear</button>
                </div>
                <div
                  class="nd-card__text nd-live-notes nd-playbook-prepare__field nd-playbook-prepare__field--notes nd-richtext nd-richtext--editor"
                  data-playbook-field="gmNotes"
                  data-richtext-editor
                  data-placeholder="Session-specific notes..."
                  role="textbox"
                  aria-label="Session-specific notes"
                ></div>
              </div>
            </div>
          </div>

          <div class="nd-playbook-prepare__sidebar">
            <div class="nd-playbook-prepare__sidebar-head">
              <div class="nd-playbook-prepare__section-title nd-hierarchy-group">Prepared Entries</div>
              <button type="button" class="nd-session-import__open" data-open-campaign-import>
                Import from Campaign
              </button>
              <button type="button" class="nd-playbook-prepare__add" data-playbook-add-beat>
                + Add Entry
              </button>
            </div>
            <div class="nd-playbook-prepare__list" data-playbook-prepare-list role="list"></div>
          </div>
        </div>

        <section class="nd-session-import" data-session-import hidden aria-label="Import from Campaign">
          <header class="nd-session-import__header">
            <div>
              <div class="nd-campaign-panel__eyebrow">Session Builder</div>
              <h2>Import from Campaign</h2>
            </div>
            <button type="button" data-close-campaign-import aria-label="Close">×</button>
          </header>
          <div class="nd-session-import__list" data-session-import-list></div>
          <footer>
            <button type="button" data-close-campaign-import>Cancel</button>
            <button type="button" class="nd-campaign-save" data-import-campaign-entries>
              Import Selected
            </button>
          </footer>
        </section>
      </article>
    </section>

  </div>

</div>
